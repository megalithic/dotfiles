#!/usr/bin/env bash
# Open anything — URLs in browser, files in editor, paths with line:col support.
# Hook for tmux-fastcopy (shift-action) and extrakto (editor).

if (($# == 0)); then
  echo "usage: tmux-open-things <path-or-url>..." >&2
  exit 1
fi

for arg in "$@"; do
  if [[ "$arg" =~ ^https?:// ]]; then
    open "$arg"
  else
    # Extract file:line:col pattern (e.g. src/main.ts:42:7)
    file="${arg%%:*}"
    rest="${arg#*:}"
    line=""
    col=""

    if [[ "$file" != "$arg" ]]; then
      line="${rest%%:*}"
      rest="${rest#*:}"
      if [[ "$line" != "$rest" ]]; then
        col="$rest"
      fi
    fi

    if [[ -n "$line" ]]; then
      ${EDITOR:-nvim} +"${line}${col:+:$col}" "$file"
    else
      ${EDITOR:-nvim} "$arg"
    fi
  fi
done
