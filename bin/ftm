#!/usr/bin/env bash

#
# ftm — fuzzy tmux session/layout switcher
#
# ftm [options] [SESSION_NAME | FUZZY_PATTERN]
#
# Running `ftm` with no argument opens a fuzzy-finder over pre-defined layouts
# and running sessions. Passing an argument switches to that session if it
# exists or creates it (layout script of the same name wins).
#
# Keybinds in the picker:
#   enter   switch/create session from selection or typed query
#   ctrl-k  kill selected session (ctrl-x also works)
#   ctrl-r  rename selected session
#   ctrl-v  switch to selected session and open pinvim pane
#
# Dependencies: tmux, fzf (>= 0.53 for native --tmux popups)
#

set -euo pipefail

__base="${0##*/}"

TMUX="${TMUX:-}"
TMUX_LAYOUTS="${TMUX_LAYOUTS:-$HOME/.config/tmux/layouts}"
POPUP="false"
PI_STATE_DIR="${PI_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/pi}"
PI_SOCKETS_DIR="$PI_STATE_DIR/sockets"

[[ -d $TMUX_LAYOUTS ]] && layouts_dir="$TMUX_LAYOUTS" || layouts_dir=""

# -- ANSI colors as literals (tput spawns a process per call)
C_RESET=$'\e[0m'
C_ITALIC=$'\e[3m'
C_MAGENTA=$'\e[35m'
C_WHITE=$'\e[38;5;255m'
C_GRAY=$'\e[38;5;245m'

function __help() {
  local tmux_running fzf_found
  [[ -n $TMUX ]] && tmux_running="running" || tmux_running="not running"
  command -v fzf &>/dev/null && fzf_found="installed" || fzf_found="not installed"

  printf -- "Usage: %s [options] [SESSION_NAME | FUZZY_PATTERN]\n" "$__base"
  printf -- "\n"
  printf -- "   Options:\n"
  printf -- "     -p              Run fzf directly (already inside a tmux popup); default uses fzf --tmux\n"
  printf -- "     -h              This help text you're presently reading. 😄\n"
  printf -- "\n"
  printf -- "   Dependencies:\n"
  printf -- "     tmux            (%s)\n" "$tmux_running"
  printf -- "     fzf             (%s)\n" "$fzf_found"
  printf -- "\n"

  exit 0
}

if ! command -v fzf &>/dev/null; then
  printf -- "ERROR: %s requires fzf to be installed\n" "$__base"
  __help
  # shellcheck disable=SC2317 # defensive; __help exits
  exit 1
fi

# -- strip picker markers (" * π" / " *") from a selection
function strip_markers() {
  local s="$1"
  s="${s% \* π}"
  s="${s% \*}"
  printf '%s' "$s"
}

# -- pre-defined layout names (one glob, no subshells)
function get_layouts() {
  local f
  [[ -n $layouts_dir ]] || return 0
  for f in "$layouts_dir"/*.sh; do
    [[ -e $f ]] || continue
    f="${f##*/}"
    printf '%s\n' "${f%.sh}"
  done
}

# -- annotated session list: layouts + running sessions, marked with * when
#    running and π when a non-ephemeral pinvim socket exists.
#    Socket pattern: $PI_SOCKETS_DIR/pi-{session}-{window}.sock
#    Pure bash string matching — no per-session process spawns.
function print_list() {
  local exclude_current="${1:-}"
  local current_sessions socks f s current_wrapped

  current_sessions="$(tmux list-sessions -F '#S' 2>/dev/null || true)"
  current_wrapped=$'\n'"$current_sessions"$'\n'

  socks=$'\n'
  for f in "$PI_SOCKETS_DIR"/pi-*.sock; do
    [[ -e $f ]] || continue
    [[ $f == *-eph-* ]] && continue
    socks+="${f##*/}"$'\n'
  done

  {
    get_layouts
    printf '%s\n' "$current_sessions"
  } | sort -u | while IFS= read -r s; do
    [[ -z $s ]] && continue
    [[ $s == "default" ]] && continue
    [[ -n $exclude_current && $s == "$exclude_current" ]] && continue
    if [[ $current_wrapped == *$'\n'"$s"$'\n'* ]]; then
      if [[ $socks == *$'\n'"pi-$s-"* ]]; then
        printf '%s * π\n' "$s"
      else
        printf '%s *\n' "$s"
      fi
    else
      printf '%s\n' "$s"
    fi
  done
}

# -- change to the given existing session
function to_session() {
  local session
  session="$(strip_markers "$1")"
  tmux "$change" -t "$session" ';' refresh-client
}

# -- new session with pre-defined layout, OR just new basic tmux session
function new_session() {
  local session="$1"
  local cwd="$2"

  if [[ -f "$layouts_dir/$session.sh" ]]; then
    # Custom layout handles pinvim
    (bash "$layouts_dir/$session.sh" &&
      to_session "$session" ||
      tmux new-session -d -s "$session" -c "${cwd}" &&
      to_session "$session") && exit
  else
    # Default layout includes pinvim
    (bash "$layouts_dir/default.sh" "$session" "${cwd}" &&
      to_session "$session" ||
      tmux new-session -d -s "$session" -c "${cwd}" &&
      to_session "$session") && exit
  fi
}

# -- try to change to an existing session; otherwise, create a new one
function try_session() {
  local session cwd line
  # first non-empty line of fzf output (query or selection), markers stripped
  session=""
  while IFS= read -r line; do
    [[ -n $line ]] && session="$(strip_markers "$line")" && break
  done <<<"$1"
  [[ -n $session ]] || exit 0

  cwd=$(zoxide query "$session" 2>/dev/null || true)

  # backup plan: use code dir if zoxide finds nothing
  if [[ -z "$cwd" ]]; then
    cwd="$HOME/code"
  fi

  to_session "$session" 2>/dev/null || new_session "$session" "${cwd}"
}

function fuzzy_find() {
  local current_session sessions_list fzf_list sessions_count
  local fzf_prompt_text fzf_header_text selected_session
  declare -a fzf_extra_args=()

  current_session="$(tmux display-message -p '#S')"
  sessions_list="$(print_list)"
  fzf_list="$(print_list "$current_session")"

  sessions_count=0
  while IFS= read -r _; do sessions_count=$((sessions_count + 1)); done <<<"$sessions_list"

  if [[ $sessions_count -le 1 ]]; then
    fzf_prompt_text=" create new session  "
    fzf_header_text=""
    fzf_list="$(get_layouts)"
    [[ -n $fzf_list ]] && fzf_header_text="󰢩 possible layouts"
  else
    fzf_prompt_text=" new or existing session  "
    fzf_header_text="󰢩 ${C_ITALIC}${C_MAGENTA}${current_session}${C_RESET} [${C_WHITE}ctrl-k${C_RESET}: ${C_GRAY}kill / ${C_WHITE}ctrl-r${C_RESET}: ${C_GRAY}rename / ${C_WHITE}ctrl-v${C_RESET}: ${C_GRAY}pinvim${C_RESET}]"
  fi

  # -- picker actions; reload regenerates the annotated list so markers stay correct
  # shellcheck disable=SC2016 # fzf action templates: {} and $() expand in fzf's shell, not here
  local kill_action='execute-silent(tmux kill-session -t "$(printf %s {} | sed -E "s/ \*( π)?$//")")+reload(ftm --list)' \
    rename_action='execute(session=$(printf %s {} | sed -E "s/ \*( π)?$//"); printf >&2 "New session name: "; read -r name; tmux rename-session -t "${session}" "${name}")+reload(ftm --list)' \
    pinvim_action='execute-silent(session=$(printf %s {} | sed -E "s/ \*( π)?$//"); tmux switch-client -t "${session}" && PIMUX_PANE=$(tmux display-message -p "#{pane_id}") pimux)+accept'

  # native fzf tmux popup unless we're already inside one (-p)
  [[ $POPUP == "true" ]] || fzf_extra_args+=(--tmux "bottom,22%")

  selected_session="$(
    fzf \
      "${fzf_extra_args[@]}" \
      --ansi \
      --reverse \
      --border=none \
      --scrollbar="▌▐" \
      --padding="1" \
      --prompt="${fzf_prompt_text}" \
      --header="${fzf_header_text}" \
      --color="bg:#3c474d,bg+:#323d43" \
      --no-preview \
      --with-shell="bash -c" \
      --bind="change:first" \
      --bind="ctrl-k:${kill_action}" \
      --bind="ctrl-x:${kill_action}" \
      --bind="ctrl-r:${rename_action}" \
      --bind="ctrl-v:${pinvim_action}" \
      --bind="enter:replace-query+print-query" \
      --pointer='▌' \
      --marker='󰛄' \
      --print-query \
      --exit-0 \
      --tac <<<"$fzf_list"
  )"

  try_session "$selected_session"
}

while getopts "phs:-:" OPTION; do
  case $OPTION in
  p)
    export TMUX_POPUP=1
    POPUP="true"
    ;;
  h)
    __help
    ;;
  s)
    echo "Saving session with session name: $OPTARG"
    exit 0
    ;;
  -)
    case "$OPTARG" in
    list)
      # internal: annotated list for fzf reload binds
      print_list "$(tmux display-message -p '#S' 2>/dev/null || true)"
      exit 0
      ;;
    help) __help ;;
    *)
      echo "Invalid Option: --$OPTARG" 1>&2
      exit 1
      ;;
    esac
    ;;
  \?)
    echo "Invalid Option: -$OPTARG" 1>&2
    exit 1
    ;;
  :)
    echo "Invalid Option: -$OPTARG requires an argument" 1>&2
    exit 1
    ;;
  esac
done
shift "$((OPTIND - 1))"

# -- this is our given session_name param, sans options
session_name="${1:-}"

[[ -n $TMUX ]] && change="switch-client" || change="attach-session"

# -- if we pass in a session_name: attach/switch to it or, create new session
if [[ $session_name ]]; then
  try_session "$session_name"
  exit 0
elif [[ -z $TMUX ]]; then
  __help
fi

fuzzy_find
