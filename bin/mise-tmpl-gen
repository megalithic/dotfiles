#!/usr/bin/env bash
# Copy a language template into a project's .config/.
#
# Usage:
#   mise-tmpl-gen <lang>       [target-dir]   # mise config + scripts
#   mise-tmpl-gen wt.<lang>    [target-dir]   # Worktrunk config + scripts
#
# Templates live in $MISE_TMPL_DIR (default ~/.dotfiles/mise/config/mise/tmpls)
# under language subdirs. The dest drops the ".local" segment so mise and
# Worktrunk file patterns match:
#   <lang>/mise.local.toml   -> <target>/.config/mise.toml
#   <lang>/wt.local.toml     -> <target>/.config/wt.toml   (Worktrunk default)
#   <lang>/scripts/*         -> <target>/.config/scripts/*
#
# wt mode also ensures <target>/.worktreeinclude lists .config/ (plus .env,
# .envrc) so Worktrunk's `wt step copy-ignored` copies the generated .config/
# into each new worktree. Additive: existing entries (build caches, deps) are
# never removed.
#
# The `scripts/` dir is copied for both modes so the generated .config/ is
# self-contained (tasks/hooks reference .config/scripts/*.sh). Target defaults
# to the directory the mise task was run from (MISE_ORIGINAL_CWD), else $PWD.
#
# Idempotent: byte-identical destinations are left untouched; differing
# destinations are replaced with a notice. mise configs are `mise trust`ed.
set -euo pipefail

tmpl_dir="${MISE_TMPL_DIR:-$HOME/.dotfiles/mise/config/mise/tmpls}"

usage() {
  echo "usage: mise-tmpl-gen <lang|wt.lang> [target-dir]" >&2
  echo "languages in $tmpl_dir:" >&2
  for d in "$tmpl_dir"/*/; do
    [ -d "$d" ] || continue
    echo "  $(basename "$d")" >&2
  done
}

if [ $# -lt 1 ] || [ $# -gt 2 ]; then
  usage
  exit 2
fi

name="$1"
mode="mise"
lang="$name"
case "$name" in
  wt.*)
    mode="wt"
    lang="${name#wt.}"
    ;;
esac

lang_dir="$tmpl_dir/$lang"
if [ ! -d "$lang_dir" ]; then
  echo "error: unknown language '$lang' ($lang_dir not found)" >&2
  usage
  exit 1
fi

case "$mode" in
  wt)
    src="$lang_dir/wt.local.toml"
    dest_name="wt.toml"
    ;;
  *)
    src="$lang_dir/mise.local.toml"
    dest_name="mise.toml"
    ;;
esac
if [ ! -f "$src" ]; then
  echo "error: template '$src' not found" >&2
  exit 1
fi

target="${2:-${MISE_ORIGINAL_CWD:-$PWD}}"
if [ ! -d "$target" ]; then
  echo "error: target directory '$target' does not exist" >&2
  exit 1
fi
dest_dir="$target/.config"
dest="$dest_dir/$dest_name"
mkdir -p "$dest_dir"

# copy_file SRC DEST [mode] — idempotent copy with a status notice.
copy_file() {
  local s="$1" d="$2" m="${3:-}"
  if [ -f "$d" ] && cmp -s "$s" "$d"; then
    echo "up-to-date: $d"
    return 0
  fi
  if [ -f "$d" ]; then
    echo "replacing (differs from template): $d"
  else
    echo "created: $d"
  fi
  cp "$s" "$d"
  [ -n "$m" ] && chmod "$m" "$d"
  return 0
}

copy_file "$src" "$dest"

# Always sync the language's scripts/ into .config/scripts/ so the generated
# config is self-contained. Executable bits preserved.
scripts_src="$lang_dir/scripts"
if [ -d "$scripts_src" ]; then
  scripts_dest="$dest_dir/scripts"
  mkdir -p "$scripts_dest"
  for s in "$scripts_src"/*; do
    [ -f "$s" ] || continue
    copy_file "$s" "$scripts_dest/$(basename "$s")" 0755
  done
fi

# wt mode: keep the .worktreeinclude allowlist in sync so copy-ignored brings
# the generated .config/ (and env files) into new worktrees. Additive only.
if [ "$mode" = "wt" ]; then
  wi="$target/.worktreeinclude"
  touch "$wi"
  wi_changed=0
  for entry in ".config/" ".env" ".envrc"; do
    if ! grep -qxF "$entry" "$wi"; then
      printf '%s\n' "$entry" >>"$wi"
      echo "worktreeinclude += $entry"
      wi_changed=1
    fi
  done
  [ "$wi_changed" -eq 0 ] && echo "worktreeinclude up-to-date: $wi"
fi

if command -v mise >/dev/null 2>&1 && [ "$dest_name" = "mise.toml" ]; then
  mise trust "$dest" >/dev/null 2>&1 || true
fi
