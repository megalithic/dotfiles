#!/usr/bin/env bash
# llm-pull — download GGUF models for llama.cpp.
#
# Default backend: llamacpp. Legacy ollama/omlx backends are obsolete after the
# local inference migration and intentionally fail with migration guidance.
set -euo pipefail

BACKEND="llamacpp"
DRY_RUN=0
ARGS=()

usage() {
  cat <<'EOF'
Usage: llm-pull [-b llamacpp] [--dry-run] <alias|repo/file.gguf> [extra hf flags...]

Backends:
  llamacpp (default)  Uses `hf download` for GGUF files under XDG_DATA_HOME/llama.cpp/models
  ollama              Obsolete after llama.cpp migration
  omlx                Obsolete after llama.cpp migration

llama.cpp aliases:
  qwen3.6       unsloth/Qwen3.6-27B-GGUF                     Qwen3.6-27B-Q4_K_M.gguf
  deepseek14b   bartowski/DeepSeek-R1-Distill-Qwen-14B-GGUF  DeepSeek-R1-Distill-Qwen-14B-Q4_K_M.gguf
  gemma4        unsloth/gemma-4-E4B-it-GGUF                  gemma-4-E4B-it-Q4_K_M.gguf
  gemma4:e2b    unsloth/gemma-4-E2B-it-GGUF                  gemma-4-E2B-it-Q4_K_M.gguf
  gemma26b      unsloth/gemma-4-26B-A4B-it-GGUF              gemma-4-26B-A4B-it-UD-Q4_K_M.gguf
  rx-gemma26b   alias for gemma26b
  qwen35b       unsloth/Qwen3.5-35B-A3B-GGUF                 Qwen3.5-35B-A3B-Q4_K_M.gguf
  rx-qwen35b    alias for qwen35b

Examples:
  llm-pull qwen3.6
  llm-pull -b llamacpp --dry-run qwen3.6
  llm-pull --dry-run gemma4:e2b
  llm-pull rx-gemma26b --resume-download

Downloads keep the upstream filename and create/refresh <alias>.gguf symlinks
so llama-server --models-dir exposes Pi model IDs such as qwen3.6 and gemma4.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h | --help)
      usage
      exit 0
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    -b | --backend)
      if [[ $# -lt 2 ]]; then
        echo "error: $1 requires a backend" >&2
        exit 2
      fi
      BACKEND="$2"
      shift 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ ${#ARGS[@]} -eq 0 ]]; then
  usage >&2
  exit 1
fi

ALIAS="${ARGS[0]}"
EXTRA=("${ARGS[@]:1}")
MODEL_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/llama.cpp/models"

find_hf() {
  local hf
  hf="$(command -v hf || true)"
  if [[ -z "$hf" ]]; then
    hf="$(command -v huggingface-cli || true)"
  fi
  if [[ -z "$hf" ]]; then
    if [[ $DRY_RUN -eq 1 ]]; then
      hf="hf"
    else
      echo "error: hf CLI not found (install huggingface_hub in your devenv/PATH)" >&2
      exit 127
    fi
  fi
  printf '%s\n' "$hf"
}

resolve_llamacpp() {
  local alias="$1"
  case "$alias" in
    qwen3.6)
      printf '%s\t%s\t%s\n' "qwen3.6" "unsloth/Qwen3.6-27B-GGUF" "Qwen3.6-27B-Q4_K_M.gguf"
      ;;
    deepseek14b)
      printf '%s\t%s\t%s\n' "deepseek14b" "bartowski/DeepSeek-R1-Distill-Qwen-14B-GGUF" "DeepSeek-R1-Distill-Qwen-14B-Q4_K_M.gguf"
      ;;
    gemma4)
      printf '%s\t%s\t%s\n' "gemma4" "unsloth/gemma-4-E4B-it-GGUF" "gemma-4-E4B-it-Q4_K_M.gguf"
      ;;
    gemma4:e2b)
      printf '%s\t%s\t%s\n' "gemma4-e2b" "unsloth/gemma-4-E2B-it-GGUF" "gemma-4-E2B-it-Q4_K_M.gguf"
      ;;
    gemma26b | rx-gemma26b)
      printf '%s\t%s\t%s\n' "gemma26b" "unsloth/gemma-4-26B-A4B-it-GGUF" "gemma-4-26B-A4B-it-UD-Q4_K_M.gguf"
      ;;
    qwen35b | rx-qwen35b)
      printf '%s\t%s\t%s\n' "qwen35b" "unsloth/Qwen3.5-35B-A3B-GGUF" "Qwen3.5-35B-A3B-Q4_K_M.gguf"
      ;;
    */*.gguf)
      local repo="${alias%/*}"
      local file="${alias##*/}"
      local model_alias="${file%.gguf}"
      printf '%s\t%s\t%s\n' "$model_alias" "$repo" "$file"
      ;;
    *)
      echo "error: unknown llama.cpp alias '$alias'" >&2
      echo "Run 'llm-pull --help' for supported aliases, or pass repo/file.gguf." >&2
      exit 2
      ;;
  esac
}

print_cmd() {
  printf '%q ' "$@"
  printf '\n'
}

pull_llamacpp() {
  local resolved model_alias repo file hf target_file alias_file
  resolved="$(resolve_llamacpp "$ALIAS")"
  IFS=$'\t' read -r model_alias repo file <<<"$resolved"

  hf="$(find_hf)"
  target_file="$MODEL_DIR/$file"
  alias_file="$MODEL_DIR/$model_alias.gguf"

  if [[ $DRY_RUN -eq 1 ]]; then
    echo ":: backend=llamacpp"
    echo ":: repo=$repo"
    echo ":: quant=Q4_K_M"
    echo ":: target=$target_file"
    echo ":: alias=$alias_file"
    print_cmd "$hf" download "$repo" --include "$file" --local-dir "$MODEL_DIR" "${EXTRA[@]}"
    print_cmd ln -sfn "$file" "$alias_file"
    exit 0
  fi

  mkdir -p "$MODEL_DIR"
  echo ":: pulling $repo/$file -> $target_file"
  "$hf" download "$repo" --include "$file" --local-dir "$MODEL_DIR" "${EXTRA[@]}"
  ln -sfn "$file" "$alias_file"
  echo ":: linked $alias_file -> $file"
}

obsolete_backend() {
  local backend="$1"
  echo "error: backend '$backend' is obsolete after migration to llama.cpp" >&2
  echo "Use: llm-pull -b llamacpp <alias>" >&2
  exit 2
}

case "$BACKEND" in
  llamacpp | llama.cpp | llama-cpp)
    pull_llamacpp
    ;;
  ollama | omlx)
    obsolete_backend "$BACKEND"
    ;;
  *)
    echo "error: unknown backend '$BACKEND' (use llamacpp)" >&2
    exit 2
    ;;
esac
