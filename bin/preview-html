#!/usr/bin/env python3
"""
preview-html - Render a markdown document as a single-page interactive HTML
               and open it in the default chromium-family browser, in the
               window with the most tabs.

Features in the rendered HTML:
  - Sticky TOC sidebar (auto-built from h2/h3)
  - Smooth-scroll on TOC click + active-section highlighting via IntersectionObserver
  - Collapsible h2 sections (default open, state persisted)
  - Interactive task checkboxes (`- [ ] X`) with localStorage persistence
  - "Decision" cards auto-rendered from headings like `### Q1:`, `### Q: ...`,
    `### ?? ...`, `### Decision:`, OR any h3/h4 nested under a `## Open questions`
  - Floating "Export answers" button: copies markdown summary to clipboard +
    downloads to ~/Downloads/<slug>-answers.md
  - Dark/light mode via prefers-color-scheme
  - Print-friendly

Usage:
  preview-html [options] <markdown-file>

Options:
  --ephemeral, -e        /tmp/preview-<slug>-<ts>.html (gc'd in 1d)
  --persist              ~/.local/share/pi/preview/<ts>-<slug>.html (default)
  --no-open              Don't open browser; just print path
  --no-gc                Skip preview-html-gc invocation
  --browser <bundle-id>  Force browser bundle id (chromium-family only)
  --title <text>         Override <title> (default: from <h1> or filename)
  -h, --help             Show this help

Env:
  PI_PREVIEW_DIR        override ~/.local/share/pi/preview
  PI_PREVIEW_BROWSER    override default-browser detection (bundle id)

Requirements:
  pandoc, macOS (LaunchServices + osascript). Chromium-family browsers only.
"""

import argparse
import datetime as dt
import json
import os
import plistlib
import re
import shutil
import subprocess
import sys
from pathlib import Path

HOME = Path.home()
PERSIST_DIR = Path(os.environ.get("PI_PREVIEW_DIR", HOME / ".local/share/pi/preview"))

# Chromium-family bundle IDs (Safari + Firefox excluded — different AppleScript dialect)
CHROMIUM_BUNDLE_IDS = {
    "com.brave.Browser.nightly": "Brave Browser Nightly",
    "com.brave.Browser.beta": "Brave Browser Beta",
    "com.brave.Browser.dev": "Brave Browser Dev",
    "com.brave.Browser": "Brave Browser",
    "com.google.Chrome": "Google Chrome",
    "com.google.Chrome.canary": "Google Chrome Canary",
    "com.google.Chrome.beta": "Google Chrome Beta",
    "com.microsoft.edgemac": "Microsoft Edge",
    "com.microsoft.edgemac.canary": "Microsoft Edge Canary",
    "com.microsoft.edgemac.beta": "Microsoft Edge Beta",
    "company.thebrowser.Browser": "Arc",
    "com.vivaldi.Vivaldi": "Vivaldi",
    "com.operasoftware.Opera": "Opera",
    "io.helium.helium": "Helium",
}

FALLBACK_BROWSER_PRIORITY = [
    "com.brave.Browser.nightly",
    "com.brave.Browser",
    "com.google.Chrome",
    "company.thebrowser.Browser",
    "com.microsoft.edgemac",
    "com.vivaldi.Vivaldi",
]


def slugify(text: str) -> str:
    s = (text or "").strip().lower()
    s = re.sub(r"[^a-z0-9._-]+", "-", s)
    s = re.sub(r"-+", "-", s).strip("-_.")
    return s or "preview"


def render_markdown(input_path: Path) -> str:
    """Run pandoc to produce an HTML body fragment."""
    if shutil.which("pandoc") is None:
        sys.exit("preview-html: pandoc required")
    cmd = [
        "pandoc",
        str(input_path),
        "--from",
        "gfm+task_lists+attributes+fenced_divs",
        "--to",
        "html5",
        "--no-highlight",
        "--wrap=preserve",
    ]
    try:
        result = subprocess.run(cmd, check=True, capture_output=True, text=True)
    except subprocess.CalledProcessError as e:
        sys.exit(f"preview-html: pandoc failed: {e.stderr or e.stdout}")
    return result.stdout


def first_h1(input_path: Path) -> str | None:
    try:
        with input_path.open("r", encoding="utf-8") as f:
            for line in f:
                m = re.match(r"^#\s+(.+?)\s*$", line)
                if m:
                    return m.group(1).strip()
    except Exception:
        return None
    return None


def detect_default_browser_bundle_id() -> str | None:
    """Read macOS LaunchServices to find the default http handler."""
    if env := os.environ.get("PI_PREVIEW_BROWSER"):
        return env
    plist = HOME / "Library/Preferences/com.apple.LaunchServices/com.apple.launchservices.secure.plist"
    if not plist.exists():
        return None
    try:
        with plist.open("rb") as f:
            data = plistlib.load(f)
    except Exception:
        return None
    for entry in data.get("LSHandlers", []):
        if entry.get("LSHandlerURLScheme") == "http":
            bid = entry.get("LSHandlerRoleAll") or entry.get("LSHandlerRoleViewer")
            if bid:
                return bid
    return None


def app_name_for_bundle_id(bundle_id: str) -> str | None:
    """Look up the .app display name for a bundle ID."""
    if bundle_id in CHROMIUM_BUNDLE_IDS:
        return CHROMIUM_BUNDLE_IDS[bundle_id]
    # Fallback: use mdfind
    try:
        out = subprocess.check_output(
            ["mdfind", f"kMDItemCFBundleIdentifier == '{bundle_id}'"],
            text=True,
            stderr=subprocess.DEVNULL,
        ).strip().splitlines()
        for path in out:
            if path.endswith(".app"):
                return Path(path).stem
    except Exception:
        pass
    return None


def is_app_running(app_name: str) -> bool:
    script = f'tell application "System Events" to (name of processes) contains "{app_name}"'
    try:
        r = subprocess.run(
            ["osascript", "-e", script], capture_output=True, text=True, timeout=5
        )
        return r.stdout.strip().lower() == "true"
    except Exception:
        return False


def pick_chromium_app() -> str:
    """Pick the chromium app to target. Prefers default → fallback chain → first running."""
    bid = detect_default_browser_bundle_id()
    if bid:
        name = app_name_for_bundle_id(bid)
        if name and bid in CHROMIUM_BUNDLE_IDS:
            return name
    # Try fallback chain (running apps first)
    for fb_bid in FALLBACK_BROWSER_PRIORITY:
        name = CHROMIUM_BUNDLE_IDS.get(fb_bid)
        if name and is_app_running(name):
            return name
    # Last resort: any chromium app installed
    for fb_bid, name in CHROMIUM_BUNDLE_IDS.items():
        try:
            r = subprocess.run(
                ["mdfind", f"kMDItemCFBundleIdentifier == '{fb_bid}'"],
                capture_output=True,
                text=True,
                timeout=5,
            )
            if r.stdout.strip():
                return name
        except Exception:
            continue
    sys.exit("preview-html: no chromium-family browser found")


def open_url_in_max_tab_window(app_name: str, url: str) -> None:
    """Open URL in the running window with the most tabs of `app_name`."""
    script = f'''
on run argv
  set theURL to item 1 of argv
  tell application "{app_name}"
    if (count of windows) is 0 then
      activate
      delay 0.4
      make new window
      set targetWin to front window
    else
      set maxCount to 0
      set targetWin to first window
      repeat with w in windows
        set tc to (count of tabs of w)
        if tc > maxCount then
          set maxCount to tc
          set targetWin to w
        end if
      end repeat
    end if
    tell targetWin
      set newTab to make new tab at end of tabs with properties {{URL:theURL}}
      set active tab index to (count of tabs)
    end tell
    set index of targetWin to 1
    activate
    return "ok: window id " & (id of targetWin) & " tabs " & (count of tabs of targetWin)
  end tell
end run
'''
    r = subprocess.run(
        ["osascript", "-", url], input=script, capture_output=True, text=True
    )
    if r.returncode != 0:
        sys.exit(f"preview-html: AppleScript failed: {r.stderr.strip()}")
    print(r.stdout.strip(), file=sys.stderr)


# ---- HTML template ----
