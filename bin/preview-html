<script>
(function(){{
  "use strict";
  var STORAGE_KEY = "preview-html:{slug}";
  var DOC_TITLE = {title_json};
  var DOC_SLUG  = {slug_json};

  var state = loadState();
  var content = document.getElementById("content");

  enhanceHeadingIds(content);
  buildTOC(content);
  wrapSectionsCollapsible(content);
  enhanceTaskCheckboxes(content);
  enhanceDecisionCards(content);
  setupActiveTOC(content);
  setupFAB();
  setupResetLink();

  function loadState(){{
    try {{ return JSON.parse(localStorage.getItem(STORAGE_KEY) || "{{}}") || {{}}; }}
    catch(e) {{ return {{}}; }}
  }}
  function saveState(){{
    try {{ localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }} catch(e){{}}
  }}
  function slugify(s){{
    return (s||"").toLowerCase().replace(/[^a-z0-9]+/g,"-").replace(/^-+|-+$/g,"").slice(0,80) || "section";
  }}
  function enhanceHeadingIds(root){{
    var seen = {{}};
    root.querySelectorAll("h1, h2, h3, h4").forEach(function(h){{
      var base = h.id || slugify(h.textContent);
      var id = base, n = 1;
      while (seen[id]) {{ id = base + "-" + (++n); }}
      seen[id] = true; h.id = id;
    }});
  }}
  function buildTOC(root){{
    var list = document.getElementById("toc-list");
    list.innerHTML = "";
    root.querySelectorAll("h2, h3").forEach(function(h){{
      var li = document.createElement("li");
      var a = document.createElement("a");
      a.href = "#" + h.id;
      a.textContent = h.textContent;
      a.className = "lvl-" + h.tagName.substring(1);
      a.dataset.target = h.id;
      li.appendChild(a); list.appendChild(li);
    }});
  }}
  function wrapSectionsCollapsible(root){{
    var openMap = state.sections || {{}};
    var nodes = Array.from(root.children);
    var i = 0;
    while (i < nodes.length) {{
      var n = nodes[i];
      if (n.tagName === "H2") {{
        var details = document.createElement("details");
        details.className = "section";
        details.id = "sec-" + n.id;
        var summary = document.createElement("summary");
        summary.appendChild(n.cloneNode(true));
        details.appendChild(summary);
        var j = i + 1, group = [];
        while (j < nodes.length && nodes[j].tagName !== "H2") {{
          group.push(nodes[j]); j++;
        }}
        group.forEach(function(g){{ details.appendChild(g); }});
        n.replaceWith(details);
        var key = details.id;
        details.open = openMap.hasOwnProperty(key) ? !!openMap[key] : true;
        details.addEventListener("toggle", function(){{
          state.sections = state.sections || {{}};
          state.sections[this.id] = this.open;
          saveState();
        }});
        i = j;
      }} else {{ i++; }}
    }}
  }}
  function enhanceTaskCheckboxes(root){{
    var saved = state.tasks || {{}};
    var n = 0;
    root.querySelectorAll("li > input[type=checkbox]").forEach(function(cb){{
      cb.disabled = false;
      var li = cb.parentElement;
      li.classList.add("task-item");
      var id = "t-" + (++n) + "-" + slugify(li.textContent.slice(0,40));
      cb.dataset.id = id;
      if (saved.hasOwnProperty(id)) cb.checked = !!saved[id];
      if (cb.checked) li.classList.add("done");
      cb.addEventListener("change", function(){{
        state.tasks = state.tasks || {{}};
        state.tasks[this.dataset.id] = this.checked;
        li.classList.toggle("done", this.checked);
        saveState();
      }});
    }});
  }}
  function isDecisionHeading(h){{
    var t = (h.textContent || "").trim();
    if (/^Q\d*\s*[:.\-]/i.test(t)) return true;
    if (/^\?\?/i.test(t)) return true;
    if (/^Decision\s*[:\-]/i.test(t)) return true;
    return false;
  }}
  function findContainingSectionTitle(el){{
    var d = el.closest("details.section");
    if (d) {{
      var s = d.querySelector("summary h2");
      if (s) return (s.textContent || "").trim();
    }}
    var n = el;
    while (n && n.previousElementSibling) {{
      n = n.previousElementSibling;
      if (n.tagName === "H2") return (n.textContent || "").trim();
    }}
    return "";
  }}
  function isOpenQuestionsSection(title){{
    return /open\s*questions?/i.test(title || "");
  }}
  function questionTextFromLi(li){{
    // Use a clone so we can strip nested children we don't want in the prompt.
    var clone = li.cloneNode(true);
    // Drop nested lists — they're sub-bullets, not the question itself.
    clone.querySelectorAll("ul, ol").forEach(function(n){{ n.remove(); }});
    var t = (clone.textContent || "").replace(/\s+/g, " ").trim();
    return t;
  }}
  function buildDecisionCard(id, qText){{
    var saved = (state.decisions || {{}})[id] || {{}};
    var card = document.createElement("div");
    card.className = "decision"; card.dataset.id = id;
    var q = document.createElement("div");
    q.className = "decision-q"; q.textContent = qText;
    card.appendChild(q);
    var opts = ["Yes","No","Maybe","Skip"];
    var optsWrap = document.createElement("div");
    optsWrap.className = "decision-options";
    opts.forEach(function(opt){{
      var label = document.createElement("label");
      var input = document.createElement("input");
      input.type = "radio"; input.name = id; input.value = opt;
      if (saved.choice === opt) input.checked = true;
      var span = document.createElement("span"); span.textContent = opt;
      label.appendChild(input); label.appendChild(span);
      input.addEventListener("change", function(){{
        state.decisions = state.decisions || {{}};
        state.decisions[id] = state.decisions[id] || {{}};
        state.decisions[id].choice = this.value;
        state.decisions[id].q = qText;
        saveState();
      }});
      optsWrap.appendChild(label);
    }});
    card.appendChild(optsWrap);
    var ta = document.createElement("textarea");
    ta.placeholder = "Notes / additional context (optional)";
    if (saved.note) ta.value = saved.note;
    ta.addEventListener("input", function(){{
      state.decisions = state.decisions || {{}};
      state.decisions[id] = state.decisions[id] || {{}};
      state.decisions[id].note = this.value;
      state.decisions[id].q = qText;
      saveState();
    }});
    card.appendChild(ta);
    return card;
  }}
  function enhanceDecisionCards(root){{
    var dn = 0;
    // Pass 1: heading-based decisions (Q:, ??, Decision:, OR any h3/h4 in an Open Questions section)
    root.querySelectorAll("h3, h4").forEach(function(h){{
      var sec = findContainingSectionTitle(h);
      var openQ = isOpenQuestionsSection(sec);
      if (!isDecisionHeading(h) && !openQ) return;
      var id = h.id || ("dq-h-" + (++dn));
      var card = buildDecisionCard(id, h.textContent);
      h.parentNode.insertBefore(card, h.nextSibling);
    }});
    // Pass 2: list-item decisions inside Open Questions sections (top-level <ol> or <ul> > <li>)
    root.querySelectorAll("ol, ul").forEach(function(list){{
      // Only consider lists whose containing section is Open Questions.
      var sec = findContainingSectionTitle(list);
      if (!isOpenQuestionsSection(sec)) return;
      // Skip nested lists — only top-level lists in the section.
      if (list.parentElement && list.parentElement.closest("li")) return;
      // Skip task lists — those are checkboxes, not questions.
      if (list.querySelector("li > input[type=checkbox]")) return;
      Array.from(list.children).forEach(function(li, idx){{
        if (li.tagName !== "LI") return;
        var qText = questionTextFromLi(li);
        if (!qText) return;
        var id = "dq-li-" + (++dn);
        var card = buildDecisionCard(id, qText);
        // Append card inside the <li> so list ordering remains.
        li.appendChild(card);
      }});
    }});
  }}
  function setupActiveTOC(root){{
    var headings = Array.from(root.querySelectorAll("h2, h3"));
    if (headings.length === 0) return;
    var links = {{}};
    document.querySelectorAll("#toc-list a").forEach(function(a){{ links[a.dataset.target] = a; }});
    var io = new IntersectionObserver(function(entries){{
      entries.forEach(function(e){{
        if (!e.isIntersecting) return;
        var id = e.target.id;
        Object.values(links).forEach(function(a){{ a.classList.remove("active"); }});
        if (links[id]) links[id].classList.add("active");
      }});
    }}, {{ rootMargin: "-15% 0px -75% 0px", threshold: 0 }});
    headings.forEach(function(h){{ io.observe(h); }});
  }}
  function toast(msg){{
    var t = document.getElementById("toast");
    t.textContent = msg; t.classList.add("show");
    setTimeout(function(){{ t.classList.remove("show"); }}, 1800);
  }}
  function buildAnswersMarkdown(){{
    var lines = [];
    lines.push("# Answers: " + DOC_TITLE);
    lines.push(""); lines.push("- Source slug: `" + DOC_SLUG + "`");
    lines.push("- Exported: " + new Date().toISOString());
    lines.push("");
    var decisions = state.decisions || {{}};
    var keys = Object.keys(decisions);
    if (keys.length) {{
      lines.push("## Decisions"); lines.push("");
      keys.forEach(function(k){{
        var d = decisions[k] || {{}};
        lines.push("### " + (d.q || k));
        lines.push("");
        lines.push("- Choice: **" + (d.choice || "(unset)") + "**");
        if (d.note) {{
          lines.push("- Notes:"); lines.push("");
          d.note.split(/\r?\n/).forEach(function(ln){{ lines.push("    " + ln); }});
        }}
        lines.push("");
      }});
    }}
    var tasks = state.tasks || {{}};
    var taskKeys = Object.keys(tasks);
    if (taskKeys.length) {{
      lines.push("## Task checkbox state"); lines.push("");
      taskKeys.forEach(function(k){{
        lines.push("- [" + (tasks[k] ? "x" : " ") + "] " + k);
      }});
      lines.push("");
    }}
    return lines.join("\n");
  }}
  function downloadText(filename, text){{
    var blob = new Blob([text], {{ type: "text/markdown;charset=utf-8" }});
    var url = URL.createObjectURL(blob);
    var a = document.createElement("a");
    a.href = url; a.download = filename;
    document.body.appendChild(a); a.click(); a.remove();
    setTimeout(function(){{ URL.revokeObjectURL(url); }}, 1000);
  }}
  function setupFAB(){{
    document.getElementById("export-btn").addEventListener("click", function(){{
      var md = buildAnswersMarkdown();
      var fname = DOC_SLUG + "-answers.md";
      if (navigator.clipboard && navigator.clipboard.writeText) {{
        navigator.clipboard.writeText(md).then(
          function(){{ toast("Answers copied + downloading " + fname); }},
          function(){{ toast("Downloading " + fname); }}
        );
      }} else {{
        toast("Downloading " + fname);
      }}
      downloadText(fname, md);
    }});
    document.getElementById("collapse-btn").addEventListener("click", function(){{
      var allOpen = Array.from(document.querySelectorAll("details.section")).every(function(d){{ return d.open; }});
      document.querySelectorAll("details.section").forEach(function(d){{ d.open = !allOpen; }});
      this.textContent = allOpen ? "Expand all" : "Collapse all";
    }});
  }}
  function setupResetLink(){{
    document.getElementById("reset-state").addEventListener("click", function(e){{
      e.preventDefault();
      if (!confirm("Reset all answers, checkboxes, and section state for this document?")) return;
      localStorage.removeItem(STORAGE_KEY); location.reload();
    }});
  }}
}})();
</script>
</body>
</html>
"""


def main() -> int:
    p = argparse.ArgumentParser(
        prog="preview-html",
        description="Render markdown as a single-page interactive HTML and open in browser.",
    )
    p.add_argument("input", help="markdown file")
    g = p.add_mutually_exclusive_group()
    g.add_argument("--ephemeral", "-e", action="store_true", help="output to /tmp")
    g.add_argument("--persist", action="store_true", help="output to ~/.local/share/pi/preview (default)")
    p.add_argument("--no-open", action="store_true")
    p.add_argument("--no-gc", action="store_true")
    p.add_argument("--browser", help="force browser bundle id (chromium-family)")
    p.add_argument("--title")
    args = p.parse_args()

    inp = Path(args.input).resolve()
    if not inp.is_file():
        sys.exit(f"preview-html: not a file: {inp}")

    body = render_markdown(inp)
    title = args.title or first_h1(inp) or inp.stem
    slug = slugify(inp.stem)
    ts = dt.datetime.now()
    ts_human = ts.strftime("%Y-%m-%d %H:%M:%S")
    ts_token = ts.strftime("%Y%m%d-%H%M%S")

    if args.ephemeral:
        out = Path(f"/tmp/preview-{slug}-{ts_token}.html")
    else:
        PERSIST_DIR.mkdir(parents=True, exist_ok=True)
        out = PERSIST_DIR / f"{ts_token}-{slug}.html"

    html = TEMPLATE.format(
        title=title.replace("<", "&lt;").replace(">", "&gt;"),
        body=body,
        slug=slug,
        ts_human=ts_human,
        title_json=json.dumps(title),
        slug_json=json.dumps(slug),
    )
    out.write_text(html, encoding="utf-8")
    print(out)

    # GC stale artifacts
    if not args.no_gc:
        gc = shutil.which("preview-html-gc")
        if gc:
            try:
                subprocess.run([gc, "--quiet"], timeout=10, check=False)
            except Exception:
                pass

    # Open in browser
    if not args.no_open:
        if args.browser:
            app_name = app_name_for_bundle_id(args.browser)
            if not app_name:
                sys.exit(f"preview-html: unknown bundle id {args.browser}")
        else:
            app_name = pick_chromium_app()
        url = "file://" + str(out)
        open_url_in_max_tab_window(app_name, url)

    return 0


if __name__ == "__main__":
    sys.exit(main())
