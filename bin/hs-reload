#!/usr/bin/env bash
# Safe Hammerspoon reload.
# Preferred path: open hammerspoon://hs-reload so Hammerspoon reloads itself.
# Avoids hs CLI IPC reload/selectMenuItem paths, which can crash Lua.

set -euo pipefail

find_hs() {
  if command -v hs >/dev/null 2>&1; then
    command -v hs
    return 0
  fi

  local home_manager_hs="$HOME/Applications/Home Manager Apps/Hammerspoon.app/Contents/Frameworks/hs/hs"
  if [[ -x "$home_manager_hs" ]]; then
    printf '%s\n' "$home_manager_hs"
    return 0
  fi

  local app_hs="/Applications/Hammerspoon.app/Contents/Frameworks/hs/hs"
  if [[ -x "$app_hs" ]]; then
    printf '%s\n' "$app_hs"
    return 0
  fi

  return 1
}

HS_BIN=$(find_hs || true)

# Get last load timestamp before reload. This is read-only IPC, not reload IPC.
get_last_load() {
  [[ -n "$HS_BIN" ]] || return 0
  "$HS_BIN" -c '
    local c = hs.console.getConsole()
    local last
    for line in c:gmatch("[^\n]+") do
      if line:match("hammerspork loaded") then last = line end
    end
    print(last or "")
  ' 2>/dev/null || echo ""
}

before=$(get_last_load)

# Preferred safe path: URL event handled inside Hammerspoon.
# Requires config/hammerspoon/init.lua to bind hs.urlevent "hs-reload".
if /usr/bin/open -g 'hammerspoon://hs-reload' >/dev/null 2>&1; then
  for _ in {1..20}; do
    sleep 0.5
    after=$(get_last_load)
    if [[ -n "$after" && "$after" != "$before" ]]; then
      echo "✓ Reloaded"
      exit 0
    fi
  done
fi

# Fallback for first install / stale running config without URL handler.
# This uses macOS Accessibility; do not replace it with hs CLI selectMenuItem.
reload_err=$(mktemp -t hs-reload.XXXXXX)
if ! osascript -e '
tell application "System Events"
    tell process "Hammerspoon"
        set reloaded to false
        repeat with mb in menu bars
            try
                click menu item "Reload Config" of menu "File" of mb
                set reloaded to true
                exit repeat
            end try
        end repeat
        if reloaded is false then error "Reload Config menu item not found"
    end tell
end tell
' >/dev/null 2>"$reload_err"; then
  err=$(cat "$reload_err")
  trash "$reload_err" 2>/dev/null || true
  echo "✗ Reload failed"
  echo "URL reload did not complete. Running Hammerspoon may not have the hs-reload URL handler loaded yet."
  if [[ "$err" == *"not allowed assistive access"* || "$err" == *"-1719"* || "$err" == *"-25211"* ]]; then
    echo "Fallback menu click also failed: /usr/bin/osascript lacks Accessibility permission in this context."
    echo "One-time fix: click Hammerspoon → File → Reload Config manually, then rerun bin/hs-reload."
  elif [[ -n "$err" ]]; then
    echo "$err"
  fi
  exit 1
fi
trash "$reload_err" 2>/dev/null || true

for _ in {1..20}; do
  sleep 0.5
  after=$(get_last_load)
  if [[ -n "$after" && "$after" != "$before" ]]; then
    echo "✓ Reloaded"
    exit 0
  fi
done

echo "✗ Reload timeout"
exit 1
