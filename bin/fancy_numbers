#!/bin/sh

usage() {
  printf 'Usage: %s [-v|--variant super|sub] [text ...]\n' "${0##*/}" >&2
}

variant=super

while [ "$#" -gt 0 ]; do
  case "$1" in
    -v|--variant)
      if [ "$#" -lt 2 ]; then
        printf '%s: missing value for %s\n' "${0##*/}" "$1" >&2
        usage
        exit 2
      fi
      variant=$2
      shift 2
      ;;
    --variant=*)
      variant=${1#--variant=}
      shift
      ;;
    --)
      shift
      break
      ;;
    -*)
      printf '%s: unknown option: %s\n' "${0##*/}" "$1" >&2
      usage
      exit 2
      ;;
    *)
      break
      ;;
  esac
done

case "$variant" in
  super|sub) ;;
  *)
    printf '%s: unsupported variant: %s\n' "${0##*/}" "$variant" >&2
    usage
    exit 2
    ;;
esac

# shellcheck disable=SC2016
awk_script='
BEGIN {
  esc = sprintf("%c", 27)

  if (variant == "sub") {
    map["0"] = "₀"; map["1"] = "₁"; map["2"] = "₂"; map["3"] = "₃"; map["4"] = "₄"
    map["5"] = "₅"; map["6"] = "₆"; map["7"] = "₇"; map["8"] = "₈"; map["9"] = "₉"
  } else {
    map["0"] = "⁰"; map["1"] = "¹"; map["2"] = "²"; map["3"] = "³"; map["4"] = "⁴"
    map["5"] = "⁵"; map["6"] = "⁶"; map["7"] = "⁷"; map["8"] = "⁸"; map["9"] = "⁹"
  }
}
{
  out = ""
  escape_state = 0

  for (i = 1; i <= length($0); i++) {
    c = substr($0, i, 1)

    if (escape_state == 1) {
      out = out c
      if (c == "[") {
        escape_state = 2
      } else {
        escape_state = 0
      }
      continue
    }

    if (escape_state == 2) {
      out = out c
      if (c ~ /[@-~]/) {
        escape_state = 0
      }
      continue
    }

    if (c == esc) {
      out = out c
      escape_state = 1
      continue
    }

    if (c in map) {
      out = out map[c]
    } else {
      out = out c
    }
  }

  print out
}
'

if [ "$#" -gt 0 ]; then
  text=$1
  shift
  while [ "$#" -gt 0 ]; do
    text=$text' '$1
    shift
  done
  printf '%s\n' "$text" | awk -v variant="$variant" "$awk_script"
elif [ ! -t 0 ]; then
  awk -v variant="$variant" "$awk_script"
else
  printf '\n'
fi
