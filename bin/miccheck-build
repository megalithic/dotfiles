#!/usr/bin/env bash
# Compile bin/miccheck.swift to a stably-signed binary at ~/.local/bin/miccheckd.
#
# Signing: prefers a Developer ID Application identity (override with
# MICCHECK_CODESIGN_IDENTITY) with a fixed identifier. TCC pins grants to
# cert + identifier, so Input Monitoring survives rebuilds. Falls back to
# ad-hoc signing (grant re-approval needed after every rebuild) when no
# identity exists.
set -euo pipefail

SRC="${DOTFILES:-$HOME/.dotfiles}/bin/miccheck.swift"
OUT="$HOME/.local/bin/miccheckd"
IDENTIFIER="com.megadots.miccheck"

IDENTITY="${MICCHECK_CODESIGN_IDENTITY:-}"
if [[ -z "$IDENTITY" ]]; then
  IDENTITY="$(security find-identity -v -p codesigning 2>/dev/null \
    | sed -n 's/.*"\(Developer ID Application: [^"]*\)".*/\1/p' | head -1)"
fi

mkdir -p "$(dirname "$OUT")"
TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"' EXIT

echo "compiling $SRC ..."
# Nix shells export SDKROOT/DEVELOPER_DIR pointing at the nix apple-sdk, which
# mismatches the system Swift toolchain. Force the Xcode CLT SDK.
unset SDKROOT DEVELOPER_DIR
SDKROOT="$(/usr/bin/xcrun --sdk macosx --show-sdk-path)"
export SDKROOT
/usr/bin/xcrun swiftc -O -o "$TMP/miccheckd" "$SRC"
if [[ -n "$IDENTITY" ]]; then
  echo "signing with: $IDENTITY (identifier $IDENTIFIER)"
  codesign -f --timestamp --options runtime -i "$IDENTIFIER" -s "$IDENTITY" "$TMP/miccheckd"
else
  echo "warning: no Developer ID identity found; ad-hoc signing (TCC grant will not survive rebuilds)" >&2
  codesign -f -i "$IDENTIFIER" -s - "$TMP/miccheckd"
fi
mv -f "$TMP/miccheckd" "$OUT"
echo "built $OUT"
echo "restart agent:"
echo "  nix:  launchctl kickstart -k gui/$(id -u)/org.nix-community.home.miccheck"
echo "  mise: launchctl kickstart -k gui/$(id -u)/com.megadots.miccheck"
