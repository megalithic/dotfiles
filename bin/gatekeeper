    // ========== MEDIUM SEVERITY - Likely Sensitive ==========
    
    PIIPattern(name: "Credit Card Number", pattern: "\\b[0-9]{4}[- ]?[0-9]{4}[- ]?[0-9]{4}[- ]?[0-9]{4}\\b", severity: .medium,
               description: "Credit card number (16 digits)"),
    PIIPattern(name: "Social Security Number", pattern: "\\b[0-9]{3}-[0-9]{2}-[0-9]{4}\\b", severity: .medium,
