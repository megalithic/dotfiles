#!/usr/bin/swift
//
// gatekeeper - Detect PII and secrets in images/text using Apple Vision OCR
//
// Usage:
//   gatekeeper <image_path> [options]
//   gatekeeper --text "string to check"
//   gatekeeper --stdin < file.txt
//
// Options:
//   --json           Output as JSON
//   --severity=LEVEL Minimum severity to report (low, medium, high)
//   --quiet          Only output if PII found
//   --text "..."     Check a text string directly (no OCR)
//   --stdin          Read text from stdin (no OCR)
//   --list-patterns  Show all detection patterns
//
// Exit codes:
//   0 = clean (no PII at or above threshold)
//   1 = warning (medium severity PII)
//   2 = blocked (high severity PII)
//   3 = error
//

import Vision
import AppKit
import Foundation

// MARK: - Pattern Definitions

struct PIIPattern {
    let name: String
    let pattern: String
    let severity: Severity
    let description: String
    
    enum Severity: String, Comparable {
        case low = "LOW"
        case medium = "MEDIUM"
        case high = "HIGH"
        
        static func < (lhs: Severity, rhs: Severity) -> Bool {
            let order: [Severity] = [.low, .medium, .high]
            return order.firstIndex(of: lhs)! < order.firstIndex(of: rhs)!
        }
    }
}

let piiPatterns: [PIIPattern] = [
    // ========== HIGH SEVERITY - Definite Secrets ==========
    
    // AWS
    PIIPattern(name: "AWS Access Key ID", pattern: "AKIA[0-9A-Z]{16}", severity: .high,
               description: "AWS access key identifier"),
    PIIPattern(name: "AWS Secret Key", pattern: "(?i)aws.{0,20}secret.{0,20}['\"][0-9a-zA-Z/+]{40}['\"]", severity: .high,
               description: "AWS secret access key"),
    PIIPattern(name: "AWS Session Token", pattern: "(?i)aws.{0,20}session.{0,20}token.{0,20}['\"][0-9a-zA-Z/+=]{100,}['\"]", severity: .high,
               description: "AWS temporary session token"),
    
