    PIIPattern(name: "Fly.io Token", pattern: "FlyV1 [a-zA-Z0-9_-]+", severity: .high,
               description: "Fly.io API token"),
    
    // Database
    PIIPattern(name: "MongoDB Connection String", pattern: "mongodb(?:\\+srv)?://[^\\s]+:[^\\s]+@[^\\s]+", severity: .high,
               description: "MongoDB connection string with credentials"),
    PIIPattern(name: "PostgreSQL Connection String", pattern: "postgres(?:ql)?://[^\\s]+:[^\\s]+@[^\\s]+", severity: .high,
               description: "PostgreSQL connection string with credentials"),
    PIIPattern(name: "MySQL Connection String", pattern: "mysql://[^\\s]+:[^\\s]+@[^\\s]+", severity: .high,
