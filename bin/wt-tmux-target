#!/usr/bin/env bash
#
# wt-tmux-target — tmux navigation helper for Worktrunk target mode.
#
# Usage:
#   wt-tmux-target --target window|session --branch <branch> --path <worktree_path>
#
# session: create/reuse a per-worktree tmux session rooted at <path> with
#          `code` and `services` windows. Inside tmux switch the client;
#          outside tmux attach (creating if needed).
# window:  inside tmux create/reuse a single current-session window rooted at
#          <path>; outside tmux degrade to session behavior.
#
# The `services` window tails Worktrunk hook logs via `wt-tail-logs <branch>`.
# It does not start services itself.

set -euo pipefail

target=""
branch=""
wpath=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      target="${2:-}"
      shift 2
      ;;
    --branch)
      branch="${2:-}"
      shift 2
      ;;
    --path)
      wpath="${2:-}"
      shift 2
      ;;
    *)
      echo "wt-tmux-target: unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if [[ "$target" != "window" && "$target" != "session" ]]; then
  echo "wt-tmux-target: --target must be window|session" >&2
  exit 2
fi
if [[ -z "$wpath" ]]; then
  echo "wt-tmux-target: --path is required" >&2
  exit 2
fi
if [[ ! -d "$wpath" ]]; then
  echo "wt-tmux-target: path does not exist: $wpath" >&2
  exit 2
fi

# Derive a base name from branch, falling back to worktree dir basename.
raw_name="$branch"
[[ -z "$raw_name" ]] && raw_name="$(basename "$wpath")"

# Sanitize: non [A-Za-z0-9_.-] -> '-', collapse repeats, trim leading/trailing '-'.
sanitized="$(printf '%s' "$raw_name" | sed -E 's/[^A-Za-z0-9_.-]+/-/g; s/-+/-/g; s/^-//; s/-$//')"
[[ -z "$sanitized" ]] && sanitized="wt"

# Append a short hash when sanitization changed the name (collision safety).
name="$sanitized"
if [[ "$sanitized" != "$raw_name" ]]; then
  short_hash="$(printf '%s' "$raw_name" | cksum | cut -d' ' -f1 | tail -c 5)"
  name="${sanitized}-${short_hash}"
fi

# Derive repo name from the main repo root. Worktrees live at
# <repo_root>/.worktrees/<branch>; strip that suffix to get the root.
repo_root="$wpath"
case "$wpath" in
  */.worktrees/*) repo_root="${wpath%/.worktrees/*}" ;;
esac
repo="$(basename "$repo_root")"
repo="$(printf '%s' "$repo" | sed -E 's/[^A-Za-z0-9_.-]+/-/g; s/-+/-/g; s/^-//; s/-$//')"
[[ -z "$repo" ]] && repo="repo"

# tmux session name is <repo>-<worktree>, e.g. rx-sm-spp-feature.
session="${repo}-${name}"

# Canonical GIT_WORKTREE id: {repo}-{branch-slug} with non [A-Za-z0-9_]
# squashed to '-'. Must stay in sync with wt.fish _wt_worktree_id and the
# mise.local.toml GIT_WORKTREE derivation (ports/DB names hash this value).
canonical_slug="$(printf '%s' "$raw_name" | sed -E 's/[^A-Za-z0-9_]+/-/g; s/-+/-/g; s/^-//; s/-$//')"
worktree_id="${repo}-${canonical_slug}"

inside_tmux="false"
[[ -n "${TMUX:-}" ]] && inside_tmux="true"

# The project's pre-start hook generates a services script in the worktree's
# PRIVATE git dir (.git/worktrees/<name>/wt-services-cmd) — never the working
# tree, so it can't be committed and is removed with the worktree. If it's
# missing (an existing worktree that predates the hook, or never ran pre-start),
# bootstrap it by running the project's pre-start hook against this worktree.
# Falls back to tailing hook logs when no project script is available.
gitdir="$(git -C "$wpath" rev-parse --absolute-git-dir 2>/dev/null)"
services_cmd_file="${gitdir:+$gitdir/wt-services-cmd}"
if [[ -n "$gitdir" && ! -f "$services_cmd_file" ]]; then
  WORKTRUNK_PROJECT_CONFIG_PATH="$repo_root/wt.local.toml" \
    wt -C "$wpath" hook pre-start -y >/dev/null 2>&1 || true
fi
if [[ -n "$services_cmd_file" && -x "$services_cmd_file" ]]; then
  services_cmd="$services_cmd_file"
else
  services_cmd="wt-tail-logs $(printf '%q' "$branch")"
fi

# Ensure a window with the given name exists in the session, rooted at $wpath.
# Reuses an existing window of the same name; never kills panes.
ensure_window() {
  local session="$1" window="$2" run_cmd="${3:-}"
  if tmux list-windows -t "=${session}" -F '#W' 2>/dev/null | grep -qx -- "$window"; then
    return 0
  fi
  if [[ -n "$run_cmd" ]]; then
    tmux new-window -d -t "=${session}" -n "$window" -c "$wpath" "$run_cmd"
  else
    tmux new-window -d -t "=${session}" -n "$window" -c "$wpath"
  fi
}

do_session() {
  if ! tmux has-session -t "=${session}" 2>/dev/null; then
    # First window becomes `code`.
    tmux new-session -d -s "$session" -c "$wpath" -n code
  fi
  tmux setenv -t "=${session}" GIT_WORKTREE "$worktree_id"
  ensure_window "$session" code
  ensure_window "$session" services "$services_cmd"

  if [[ "$inside_tmux" == "true" ]]; then
    tmux switch-client -t "=${session}"
  else
    tmux attach-session -t "=${session}"
  fi
}

do_window() {
  # Outside tmux there is no current session to add a window to.
  if [[ "$inside_tmux" != "true" ]]; then
    do_session
    return
  fi
  local cur
  cur="$(tmux display-message -p '#S')"
  tmux setenv -t "=${cur}" GIT_WORKTREE "$worktree_id"
  if tmux list-windows -t "=${cur}" -F '#W' 2>/dev/null | grep -qx -- "$name"; then
    tmux select-window -t "=${cur}:${name}"
  else
    tmux new-window -t "=${cur}" -n "$name" -c "$wpath"
  fi
}

case "$target" in
  session) do_session ;;
  window) do_window ;;
esac
