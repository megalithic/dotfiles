#!/usr/bin/env python3
"""Check (not write) 1Password's trusted-browser entry for Helium.

1Password for Mac stores custom trusted browsers in settings.json under
"browsers.other-trusted-apps": a JSON-encoded string mapping
base64url(bundle id) -> {path, name, signing_info, trust_source}, where
signing_info is base64url of a codesign requirement pinned to the app's
signing team (subject.OU).

The value is integrity-protected: 1Password detects external edits at startup
and resets them ("setting for browsers.other-trusted-apps had an untrusted
value, it will be reset!"), so this CANNOT be managed declaratively. The only
supported path is the GUI, one time per machine per signing team:

    1Password -> Settings -> Browser -> Add Browser -> /Applications/Helium.app

This script verifies the entry exists and pins the same team that signed the
installed app; exits 1 with instructions when action is needed.

Usage: helium-1password-trust [--app /Applications/Helium.app]
"""

import base64
import json
import re
import subprocess
import sys
from pathlib import Path

APP = "/Applications/Helium.app"
BUNDLE_ID = "net.imput.helium"
SETTINGS = Path.home() / (
    "Library/Group Containers/2BUA8C4S2C.com.1password"
    "/Library/Application Support/1Password/Data/settings/settings.json"
)

GUI_STEPS = """\
!! Helium is not trusted by 1Password (or the pinned signing team is stale).
   1Password integrity-protects this setting; it must be added via the GUI:

     1. Open and unlock 1Password
     2. Settings -> Browser -> Add Browser
     3. Pick /Applications/Helium.app

   One time per machine per signing team; releases signed by the same team
   stay trusted across version bumps."""


def b64url(s: str) -> str:
    return base64.urlsafe_b64encode(s.encode()).decode().rstrip("=")


def team_identifier(app: str) -> str:
    out = subprocess.run(
        ["/usr/bin/codesign", "-dv", app],
        capture_output=True,
        text=True,
        check=True,
    ).stderr
    m = re.search(r"^TeamIdentifier=(\S+)$", out, re.M)
    if not m or m.group(1) == "not set":
        sys.exit(f"!! {app} has no TeamIdentifier (unsigned or ad-hoc)")
    return m.group(1)


def main() -> None:
    app = APP
    if len(sys.argv) == 3 and sys.argv[1] == "--app":
        app = sys.argv[2]

    if not Path(app).is_dir():
        sys.exit(f"!! {app} not installed")
    if not SETTINGS.is_file():
        sys.exit(f"!! 1Password settings not found: {SETTINGS}")

    team = team_identifier(app)

    settings = json.loads(SETTINGS.read_text())
    trusted = json.loads(settings.get("browsers.other-trusted-apps", "{}") or "{}")
    entry = trusted.get(b64url(BUNDLE_ID))

    if entry:
        sig = entry.get("signing_info", "")
        requirement = base64.urlsafe_b64decode(sig + "=" * (-len(sig) % 4)).decode()
        if f'"{team}"' in requirement:
            print(f":: 1Password trusts {app} (team {team})")
            return
        print(f"!! 1Password trusts {app} but pins a different team than {team}")

    sys.exit(GUI_STEPS)


if __name__ == "__main__":
    main()
