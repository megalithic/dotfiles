#!/usr/bin/env python3
"""Trust /Applications/Helium.app in 1Password for desktop<->extension pairing.

Equivalent to 1Password Settings -> Browser -> Add Browser, but declarative.
1Password for Mac stores custom trusted browsers in settings.json under
"browsers.other-trusted-apps": a JSON-encoded string mapping
base64url(bundle id) -> {path, name, signing_info, trust_source}, where
signing_info is base64url of a codesign requirement pinned to the app's
signing team (subject.OU).

The app must be quit when this runs: a running 1Password rewrites
settings.json from memory and would clobber the merge.

Usage: helium-1password-trust [--app /Applications/Helium.app]
"""

import base64
import json
import re
import subprocess
import sys
from pathlib import Path

APP = "/Applications/Helium.app"
BUNDLE_ID = "net.imput.helium"
NAME = "Helium"
SETTINGS = Path.home() / (
    "Library/Group Containers/2BUA8C4S2C.com.1password"
    "/Library/Application Support/1Password/Data/settings/settings.json"
)

# Same requirement template 1Password generates via "Add Browser":
# Apple-anchored Developer ID / App Store chain AND leaf team OU pin.
REQUIREMENT_TEMPLATE = """anchor apple generic and (
\t\tcertificate leaf[field.1.2.840.113635.100.6.1.9] or certificate leaf[field.1.2.840.113635.100.6.1.3] or certificate leaf[field.1.2.840.113635.100.6.1.6] or certificate leaf[field.1.2.840.113635.100.6.1.25.1] or certificate 1[field.1.2.840.113635.100.6.2.6] and certificate leaf[field.1.2.840.113635.100.6.1.13]
) and (certificate leaf[subject.OU] = "{team}" or certificate leaf[field.1.2.840.113635.100.6.1.9] or certificate leaf[field.1.2.840.113635.100.6.1.3] or certificate leaf[field.1.2.840.113635.100.6.1.6] exists)"""


def b64url(s: str) -> str:
    return base64.urlsafe_b64encode(s.encode()).decode().rstrip("=")


def team_identifier(app: str) -> str:
    out = subprocess.run(
        ["/usr/bin/codesign", "-dv", app],
        capture_output=True,
        text=True,
        check=True,
    ).stderr
    m = re.search(r"^TeamIdentifier=(\S+)$", out, re.M)
    if not m or m.group(1) == "not set":
        sys.exit(f"!! {app} has no TeamIdentifier (unsigned or ad-hoc)")
    return m.group(1)


def onepassword_running() -> bool:
    return (
        subprocess.run(
            ["/usr/bin/pgrep", "-x", "1Password"], capture_output=True
        ).returncode
        == 0
    )


def main() -> None:
    app = APP
    if len(sys.argv) == 3 and sys.argv[1] == "--app":
        app = sys.argv[2]

    if not Path(app).is_dir():
        sys.exit(f"!! {app} not installed")
    if not SETTINGS.is_file():
        sys.exit(f"!! 1Password settings not found: {SETTINGS}")

    team = team_identifier(app)
    entry = {
        "path": app,
        "name": NAME,
        "signing_info": b64url(REQUIREMENT_TEMPLATE.format(team=team)),
        "trust_source": "Codesigning",
    }

    settings = json.loads(SETTINGS.read_text())
    trusted = json.loads(settings.get("browsers.other-trusted-apps", "{}") or "{}")
    key = b64url(BUNDLE_ID)

    if trusted.get(key) == entry:
        print(f":: 1Password already trusts {app} (team {team}); nothing to do")
        return

    if onepassword_running():
        sys.exit(
            "!! 1Password is running and would overwrite settings.json.\n"
            "   Quit 1Password fully (menu bar icon -> Quit), rerun, then reopen it."
        )

    trusted[key] = entry
    settings["browsers.other-trusted-apps"] = json.dumps(trusted, separators=(",", ":"))
    SETTINGS.write_text(json.dumps(settings, separators=(",", ":")))
    print(f":: Trusted {app} (team {team}) in 1Password; start 1Password to pick it up")


if __name__ == "__main__":
    main()
