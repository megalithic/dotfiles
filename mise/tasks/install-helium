#!/bin/sh
# Manual fallback: install Helium.app from megalithic/helium-macos-releases.
# The normal path is the [tools."github:megalithic/helium-macos-releases"]
# entry in global_config.toml (mise downloads the DMG, install-app.sh mounts
# and copies it). This script does the same via the GitHub API directly.
#
# The repo is public now, so a token is optional (raises API rate limits).
# Verifies the published sha256.
#
# Env:
#   HOMEBREW_GITHUB_API_TOKEN / GITHUB_TOKEN  optional auth
#   HELIUM_INSTALL_DIR                        target dir (default /Applications)
set -eu

REPO="megalithic/helium-macos-releases"
INSTALL_DIR="${HELIUM_INSTALL_DIR:-/Applications}"
APP="$INSTALL_DIR/Helium.app"

[ -d "$APP" ] && {
  echo "install-helium: $APP already installed"
  exit 0
}

# Token is optional (public repo); use one when available for rate limits.
# mise bootstrap hooks don't receive [env], so source the rendered secrets
# (fnox first, opnix fallback) when no token is in the environment already.
TOKEN="${HOMEBREW_GITHUB_API_TOKEN:-${GITHUB_TOKEN:-}}"
if [ -z "$TOKEN" ]; then
  for secrets in "$HOME/.config/fnox/secrets/env-vars.sh" "$HOME/.config/opnix/secrets/env-vars.sh"; do
    # shellcheck disable=SC1090
    [ -f "$secrets" ] && . "$secrets" && break
  done
  TOKEN="${HOMEBREW_GITHUB_API_TOKEN:-${GITHUB_TOKEN:-}}"
fi

ARCH=$(uname -m) # arm64 / x86_64
WORKDIR=$(mktemp -d "${TMPDIR:-/tmp}/install-helium.XXXXXX")
MOUNTPOINT="$WORKDIR/mnt"
cleanup() {
  [ -d "$MOUNTPOINT" ] && hdiutil detach "$MOUNTPOINT" -quiet 2>/dev/null
  rm -rf "$WORKDIR"
}
trap cleanup EXIT INT TERM

api() {
  if [ -n "$TOKEN" ]; then
    curl -fsSL -H "Authorization: Bearer $TOKEN" -H "Accept: ${1}" "$2"
  else
    curl -fsSL -H "Accept: ${1}" "$2"
  fi
}

echo "install-helium: resolving latest release..."
RELEASE_JSON="$WORKDIR/release.json"
api "application/vnd.github+json" "https://api.github.com/repos/$REPO/releases/latest" >"$RELEASE_JSON"

# Pull "<asset id> <asset name>" pairs out of the release JSON without jq:
# in each asset object "id" precedes "name", so remember the last id seen.
asset_id_for() {
  tr ',' '\n' <"$RELEASE_JSON" | awk -v want="$1" '
    /"id":/ { gsub(/[^0-9]/, ""); id = $0 }
    /"name":/ { gsub(/.*"name": *"|".*/, ""); if ($0 == want) { print id; exit } }
  '
}

DMG_NAME=$(tr ',' '\n' <"$RELEASE_JSON" |
  sed -n 's/.*"name": *"\(helium_[^"]*_'"$ARCH"'-macos\.dmg\)".*/\1/p' | head -1)
[ -n "$DMG_NAME" ] || {
  echo "install-helium: no $ARCH DMG asset in latest release" >&2
  exit 1
}

DMG_ID=$(asset_id_for "$DMG_NAME")
SHA_ID=$(asset_id_for "$DMG_NAME.sha256")
[ -n "$DMG_ID" ] || {
  echo "install-helium: could not resolve asset id for $DMG_NAME" >&2
  exit 1
}

echo "install-helium: downloading $DMG_NAME..."
api "application/octet-stream" "https://api.github.com/repos/$REPO/releases/assets/$DMG_ID" >"$WORKDIR/$DMG_NAME"

if [ -n "$SHA_ID" ]; then
  api "application/octet-stream" "https://api.github.com/repos/$REPO/releases/assets/$SHA_ID" >"$WORKDIR/$DMG_NAME.sha256"
  echo "install-helium: verifying sha256..."
  (cd "$WORKDIR" && shasum -a 256 -c "$DMG_NAME.sha256" >/dev/null) || {
    echo "install-helium: sha256 verification FAILED for $DMG_NAME" >&2
    exit 1
  }
else
  echo "install-helium: warning: no .sha256 asset published; skipping verification" >&2
fi

echo "install-helium: mounting and copying to $INSTALL_DIR..."
mkdir -p "$MOUNTPOINT"
hdiutil attach "$WORKDIR/$DMG_NAME" -nobrowse -quiet -mountpoint "$MOUNTPOINT"
SRC_APP=$(find "$MOUNTPOINT" -maxdepth 1 -name '*.app' | head -1)
[ -n "$SRC_APP" ] || {
  echo "install-helium: no .app found in DMG" >&2
  exit 1
}
mkdir -p "$INSTALL_DIR"
cp -R "$SRC_APP" "$APP"
hdiutil detach "$MOUNTPOINT" -quiet
rmdir "$MOUNTPOINT" 2>/dev/null || true

echo "install-helium: installed $APP"
