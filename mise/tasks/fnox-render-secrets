#!/usr/bin/env bash
# Render file-shaped fnox secrets to ~/.config/fnox/secrets (fnox twin of the
# opnix render step). Invoked via `mise run setup:fnox:render`; fnox resolves
# ENV_VARS_SH (op://Crypt/env/notesPlain) through the global fnox config.
#
# If the 1Password vault referenced in the config doesn't exist on this
# account (e.g. work machine using a different 1Password account), warn and
# exit 0 so bootstrap continues. The user can configure the correct vault
# later and re-run `mise run setup:fnox:render`.
set -euo pipefail

secrets_dir="${XDG_CONFIG_HOME:-$HOME/.config}/fnox/secrets"
umask 077
mkdir -p "$secrets_dir"

tmp="$(mktemp "$secrets_dir/.env-vars.sh.XXXXXX")"
trap 'rm -f "$tmp"' EXIT

if ! fnox_err=$(fnox get ENV_VARS_SH 2>&1 >"$tmp"); then
  echo "fnox-render-secrets: could not render ENV_VARS_SH:" >&2
  echo "  $fnox_err" >&2
  echo "  If this is a work machine with a different 1Password account," >&2
  echo "  update the vault in ~/.config/fnox/config.toml and re-run" >&2
  echo "  'mise run setup:fnox:render'." >&2
  # Don't fail — let bootstrap continue. Shell init will source the old file
  # if one exists, or skip silently if not.
  exit 0
fi

[ -s "$tmp" ] || {
  echo "fnox-render-secrets: ENV_VARS_SH resolved empty; keeping existing file" >&2
  exit 0
}
mv "$tmp" "$secrets_dir/env-vars.sh"
trap - EXIT
echo "rendered $secrets_dir/env-vars.sh"