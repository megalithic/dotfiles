+/**
+ * Find project-specific .claude-* directories (e.g., .claude-rx, .claude-cspire)
+ * Returns paths to check in order: .claude.json, settings.json, settings.local.json
+ */
+function findClaudeProjectDirs(cwd: string): string[] {
+  const paths: string[] = [];
+  try {
+    const entries = readdirSync(cwd, { withFileTypes: true });
+    for (const entry of entries) {
+      // Match .claude-* directories (but not .claude-plugin or just .claude)
+      if (entry.isDirectory() && /^\.claude-[a-zA-Z0-9_-]+$/.test(entry.name) && entry.name !== '.claude-plugin') {
+        const dir = join(cwd, entry.name);
+        // Add in order: .claude.json, settings.json, settings.local.json
+        paths.push(join(dir, ".claude.json"));
+        paths.push(join(dir, "settings.json"));
+        paths.push(join(dir, "settings.local.json"));
+      }
+    }
+  } catch {
+    // Ignore errors reading directory
+  }
+  return paths;
+}
+
+/**
+ * Extract mcpServers from a config object
+ */
+function extractMcpServers(raw: unknown): Record<string, ServerEntry> | null {
+  if (!raw || typeof raw !== "object") return null;
+  const obj = raw as Record<string, unknown>;
+  const servers = obj.mcpServers;
+  if (!servers || typeof servers !== "object" || Array.isArray(servers)) return null;
+  return servers as Record<string, ServerEntry>;
+}
