{
  "retry": {
    "baseDelayMs": 1000,
    "maxDelayMs": 900000,
    "provider": {
      "timeoutMs": 3600000
    }
  },
  "defaultProvider": "openai-codex",
  "defaultThinkingLevel": "medium",
  "doubleEscapeAction": "tree",
  "enableSkillCommands": true,
  "hideThinkingBlock": true,
  "editorPaddingX": 1,
  "packages": [
    "npm:pi-mcp-adapter",
    "npm:pi-web-access",
    "npm:pi-subagents",
    "npm:pi-caveman",
    "npm:pi-rtk-optimizer"
  ],
  "enabledModels": [
    "rx-anthropic/claude-opus-4-7",
    "rx-anthropic/claude-opus-4-6",
    "rx-anthropic/claude-sonnet-4-5",
    "rx-anthropic/claude-haiku-4-5",
    "rx-codex/gpt-5.5",
    "rx-codex/gpt-5.4",
    "rx-codex/gpt-5.4-mini",
    "rx-codex/gpt-5.3-codex-spark",
    "google-vertex/gemini-3.1-pro-preview",
    "google-vertex/gemini-3-flash-preview",
    "openai-codex/gpt-5.5",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.4-mini",
    "openai-codex/gpt-5.3-codex-spark",
    "synthetic/hf:zai-org/GLM-5.1",
    "synthetic/hf:MiniMaxAI/MiniMax-M2.5",
    "synthetic/hf:moonshotai/Kimi-K2.6",
    "llamacpp/qwen3.6",
    "llamacpp/deepseek14b",
    "llamacpp/gemma4"
  ],
  "enabledModelScopes": {
    "mega": [
      "openai-codex/gpt-5.5",
      "openai-codex/gpt-5.4",
      "openai-codex/gpt-5.4-mini",
      "openai-codex/gpt-5.3-codex-spark",
      "synthetic/hf:zai-org/GLM-5.1",
      "synthetic/hf:moonshotai/Kimi-K2.6",
      "synthetic/hf:MiniMaxAI/MiniMax-M2.5",
      "llamacpp/qwen3.6",
      "llamacpp/deepseek14b",
      "llamacpp/gemma4"
    ],
    "rx": [
      "rx-anthropic/claude-opus-4-6",
      "rx-anthropic/claude-sonnet-4-5",
      "rx-anthropic/claude-haiku-4-5",
      "rx-codex/gpt-5.5",
      "rx-codex/gpt-5.4",
      "rx-codex/gpt-5.4-mini",
      "rx-codex/gpt-5.3-codex-spark",
      "google-vertex/gemini-3.1-pro-preview",
      "google-vertex/gemini-3-flash-preview"
    ]
  },
  "terminal": {
    "showTerminalProgress": true,
    "imageWidthCells": 120
  },
  "multiSub": {
    "subscriptions": [
      {
        "provider": "anthropic",
        "alias": "rx-anthropic",
        "label": "rx-anthropic"
      },
      {
        "provider": "openai-codex",
        "alias": "rx-codex",
        "label": "rx-codex"
      }
    ],
    "pools": [],
    "chains": [],
    "presets": [
      {
        "name": "mega",
        "entries": [
          {
            "provider": "openai-codex",
            "model": "gpt-5.5",
            "enabled": true
          },
          {
            "provider": "openai-codex",
            "model": "gpt-5.4",
            "enabled": true
          },
          {
            "provider": "openai-codex",
            "model": "gpt-5.4-mini",
            "enabled": true
          }
        ],
        "enabled": true
      },
      {
        "name": "rx",
        "entries": [
          {
            "provider": "rx-anthropic",
            "model": "claude-opus-4-6",
            "enabled": true
          },
          {
            "provider": "rx-anthropic",
            "model": "claude-sonnet-4-5",
            "enabled": true
          },
          {
            "provider": "rx-anthropic",
            "model": "claude-haiku-4-5",
            "enabled": true
          },
          {
            "provider": "rx-codex",
            "model": "gpt-5.5",
            "enabled": true
          },
          {
            "provider": "rx-codex",
            "model": "gpt-5.4",
            "enabled": true
          },
          {
            "provider": "rx-codex",
            "model": "gpt-5.4-mini",
            "enabled": true
          }
        ],
        "enabled": true
      }
    ],
    "directoryProfiles": [
      {
        "glob": "~/code/work/strive/**",
        "preset": "rx",
        "modelScope": "rx"
      }
    ]
  },
  "shellCommandPrefix": "export GIT_EDITOR=true\nexport GIT_SEQUENCE_EDITOR=true\nexport GIT_TERMINAL_PROMPT=0\n export PI_TMUX_IMAGES=1",
  "subagents": {
    "agentOverrides": {
      "planner": {
        "model": "rx-anthropic/claude-opus-4-7",
        "fallbackModels": [
          "rx-anthropic/claude-opus-4-6",
          "openai-codex/gpt-5.5",
          "synthetic/hf:zai-org/GLM-5.1"
        ],
        "thinking": "medium"
      },
      "reviewer": {
        "model": "rx-anthropic/claude-opus-4-7",
        "fallbackModels": [
          "rx-anthropic/claude-opus-4-6",
          "openai-codex/gpt-5.5",
          "synthetic/hf:zai-org/GLM-5.1"
        ],
        "thinking": "medium"
      },
      "oracle": {
        "model": "rx-anthropic/claude-opus-4-7",
        "fallbackModels": [
          "rx-anthropic/claude-opus-4-6",
          "openai-codex/gpt-5.5",
          "synthetic/hf:zai-org/GLM-5.1"
        ]
      },
      "worker": {
        "model": "rx-anthropic/claude-sonnet-4-5",
        "fallbackModels": [
          "rx-codex/gpt-5.5",
          "openai-codex/gpt-5.5",
          "synthetic/hf:moonshotai/Kimi-K2.6"
        ]
      },
      "researcher": {
        "model": "rx-anthropic/claude-sonnet-4-5",
        "fallbackModels": [
          "rx-codex/gpt-5.5",
          "openai-codex/gpt-5.5",
          "synthetic/hf:moonshotai/Kimi-K2.6"
        ]
      },
      "scout": {
        "model": "rx-anthropic/claude-haiku-4-5",
        "fallbackModels": [
          "google-vertex/gemini-3-flash-preview",
          "openai-codex/gpt-5.4-mini",
          "llamacpp/gemma4"
        ]
      },
      "context-builder": {
        "model": "rx-anthropic/claude-haiku-4-5",
        "fallbackModels": [
          "google-vertex/gemini-3-flash-preview",
          "openai-codex/gpt-5.4-mini",
          "llamacpp/gemma4"
        ]
      }
    }
  }
}
