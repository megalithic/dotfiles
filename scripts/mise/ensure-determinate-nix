#!/usr/bin/env bash
# Install or repair Nix using the official NixOS installer.
# Replaces the deprecated Determinate Systems installer.
#   curl -sSfL https://artifacts.nixos.org/nix-installer | sh -s -- install --enable-flakes
set -euo pipefail

if command -v nix >/dev/null 2>&1 && { [ -x /nix/nix-installer ] || [ -x /nix/nix-installer/bin/nix-installer ]; }; then
  echo "Nix appears installed (nix-installer marker found)."
  exit 0
fi

if command -v nix >/dev/null 2>&1; then
  echo "nix exists, but nix-installer marker not found. Review before reinstalling." >&2
  echo "See https://github.com/NixOS/nix-installer" >&2
  exit 1
fi

curl -sSfL https://artifacts.nixos.org/nix-installer | sh -s -- install --enable-flakes
