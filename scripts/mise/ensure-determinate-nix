#!/usr/bin/env bash
set -euo pipefail

if command -v nix >/dev/null 2>&1 && { [ -x /nix/nix-installer ] || [ -x /nix/nix-installer/bin/nix-installer ]; }; then
  echo "Determinate Nix appears installed."
  exit 0
fi

if command -v nix >/dev/null 2>&1; then
  echo "nix exists, but Determinate installer marker not found. Review before reinstalling." >&2
  echo "See https://docs.determinate.systems/" >&2
  exit 1
fi

curl -fsSL https://install.determinate.systems/nix | sh -s -- install --determinate
