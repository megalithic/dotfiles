#!/usr/bin/env bash
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

fail=0
check_cmd() {
  local cmd="$1"
  if command -v "$cmd" >/dev/null 2>&1; then
    echo "ok: $cmd"
  else
    echo "missing: $cmd" >&2
    fail=1
  fi
}

check_path() {
  local path="$1"
  if [ -e "$path" ] || [ -L "$path" ]; then
    echo "ok: $path"
  else
    echo "missing: $path" >&2
    fail=1
  fi
}

check_cmd mise
check_cmd brew
check_cmd fnox
check_cmd op
check_cmd fish
check_cmd git
check_cmd rg
check_cmd fd
check_cmd jq
check_path mise.toml
check_path mise/Brewfile
check_path mise/fnox/config.toml
check_path config/nvim
check_path home/common/programs/pi-coding-agent

scripts/mise/dotfile-preflight || fail=1

if command -v mise >/dev/null 2>&1; then
  mise --version || true
fi

if [ "$fail" -ne 0 ]; then
  echo "doctor: attention needed" >&2
  exit 1
fi

echo "doctor: ok"
